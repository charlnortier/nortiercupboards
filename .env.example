# ─── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Paystack (Payments) ──────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxxxx

# ─── Email (Resend primary, SMTP fallback) ────────────────
RESEND_API_KEY=re_xxxxx
RESEND_FROM=Your Company <hello@example.com>
ADMIN_EMAIL=admin@example.com

# Optional SMTP fallback (used when Resend is unavailable)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password

# ─── Site ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Your Company

# ─── Cron Jobs ────────────────────────────────────────────
# Random secret used to authenticate Vercel cron requests
CRON_SECRET=your-random-secret-here

# ─── Analytics ────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
